{
  "name": "refract-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Agent-first responsive screenshots — MCP server + CLI + Node library on Playwright.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.31.0",
    "@getrefractjs/core": "workspace:*",
    "@types/node": "^22.10.2",
    "gifenc": "^1.0.3",
    "sharp": "^0.33.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
