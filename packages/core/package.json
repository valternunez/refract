{
  "name": "@getrefractjs/core",
  "version": "0.0.0",
  "description": "Refract core — render() at N viewports on Playwright, returns screenshots and findings.",
  "keywords": ["refract", "responsive", "screenshots", "playwright", "viewport", "visual-testing", "findings"],
  "author": "Valter Núñez",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "playwright": "^1.49.1"
  }
}
